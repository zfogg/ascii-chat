source .env

repo_root="$(git rev-parse --show-toplevel)"

export FPATH="$repo_root/build/share/zsh/site-functions:$FPATH"
export MANPATH="$repo_root/build/share/man:$MANPATH"

export ASAN_OPTIONS="suppressions=$repo_root/.asan-suppressions:verbosity=0:halt_on_error=1"
export UBSAN_OPTIONS="suppressions=$repo_root/.ubsan-suppressions"
export LSAN_OPTIONS="suppressions=$repo_root/.lsan-suppressions"
export TSAN_OPTIONS="log_path=$repo_root/build/tsan.log:halt_on_error=1:verbosity=0"

brew_prefix="$(brew --prefix)"

export PKG_CONFIG_PATH="/usr/local/lib/pkgconfig:/usr/local/share/pkgconfig:$PKG_CONFIG_PATH"
export PKG_CONFIG_PATH="$brew_prefix/lib/pkgconfig:$brew_prefix/share/pkgconfig:$PKG_CONFIG_PATH"
export PKG_CONFIG_PATH="$repo_root/build/lib/pkgconfig:$repo_root/build/share/pkgconfig:$PKG_CONFIG_PATH"

layout uv
