:80 {
  root * /app/web/dist

  # COEP/COOP headers for SharedArrayBuffer support (required for WASM threads)
  header Cross-Origin-Embedder-Policy "require-corp"
  header Cross-Origin-Opener-Policy "same-origin"

  # Rewrites from vercel.json: /, /mirror, /client, /discovery
  @sparoutes {
    path / /mirror /client /discovery
  }
  rewrite @sparoutes /index.html

  file_server

  # Handle 404 errors for non-existent routes
  handle_errors 404 {
    rewrite * /404.html
    file_server
  }
}
