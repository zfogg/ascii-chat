:80 {
  root * /app/web/dist

  # COEP/COOP headers for SharedArrayBuffer support (required for WASM threads)
  header Cross-Origin-Embedder-Policy "require-corp"
  header Cross-Origin-Opener-Policy "same-origin"

  # CORS for .wasm files (allows ascii-chat.com to fetch mirror.wasm cross-origin)
  handle /wasm/* {
    header Access-Control-Allow-Origin "https://ascii-chat.com"
    header Cross-Origin-Resource-Policy "cross-origin"
    file_server
  }

  # Cache static assets with content hashes for 1 year (immutable)
  handle /assets/* {
    header Cache-Control "public, max-age=31536000, immutable"
    file_server
  }

  # Rewrites: /, /mirror, /client, /discovery, /404
  @sparoutes {
    path / /404 /mirror /client /discovery
  }
  handle @sparoutes {
    rewrite * /index.html
    header Cache-Control "public, max-age=3600"
    file_server
  }

  # Default file server for remaining files (1 hour cache)
  handle {
    header Cache-Control "public, max-age=3600"
    file_server
  }

  # Handle 404 errors for non-existent routes
  handle_errors 404 {
    rewrite * /404.html
    file_server
  }
}
