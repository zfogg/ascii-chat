:80 {
  root * /app/web/dist

  # COEP/COOP headers for SharedArrayBuffer support (required for WASM threads)
  header Cross-Origin-Embedder-Policy "require-corp"
  header Cross-Origin-Opener-Policy "same-origin"

  # CORS for .wasm files (allows ascii-chat.com and www.ascii-chat.com to fetch mirror.wasm cross-origin)
  @wasm_cors_main {
    path /wasm/*
    header Origin "https://ascii-chat.com"
  }
  @wasm_cors_www {
    path /wasm/*
    header Origin "https://www.ascii-chat.com"
  }
  @wasm_no_cors {
    path /wasm/*
    not header Origin "https://ascii-chat.com"
    not header Origin "https://www.ascii-chat.com"
  }
  handle @wasm_cors_main {
    header Access-Control-Allow-Origin "https://ascii-chat.com"
    header Cross-Origin-Resource-Policy "cross-origin"
    file_server
  }
  handle @wasm_cors_www {
    header Access-Control-Allow-Origin "https://www.ascii-chat.com"
    header Cross-Origin-Resource-Policy "cross-origin"
    file_server
  }
  handle @wasm_no_cors {
    header Cross-Origin-Resource-Policy "cross-origin"
    file_server
  }

  # Serve fonts from www's dist directory (single source of truth)
  handle /fonts/* {
    root * /app/web/www/dist
    header Cache-Control "public, max-age=31536000, immutable"
    file_server
  }

  # Cache static assets with content hashes for 1 year (immutable)
  handle /assets/* {
    header Cache-Control "public, max-age=31536000, immutable"
    file_server
  }

  # Rewrites: /, /mirror, /client, /discovery, /404
  @sparoutes {
    path / /404 /mirror /client /discovery
  }
  handle @sparoutes {
    rewrite * /index.html
    header Cache-Control "public, max-age=3600"
    file_server
  }

  # Default file server for remaining files (1 hour cache)
  handle {
    header Cache-Control "public, max-age=3600"
    file_server
  }

  # Handle 404 errors for non-existent routes
  handle_errors 404 {
    rewrite * /404.html
    file_server
  }
}
