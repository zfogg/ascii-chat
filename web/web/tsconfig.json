{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@wasm/*": ["./public/wasm/*"],
      "@ascii-chat/shared": ["../packages/shared/src/index.ts"],
      "@ascii-chat/shared/components": [
        "../packages/shared/src/components/index.ts"
      ],
      "@ascii-chat/shared/hooks": [
        "../packages/shared/src/hooks/index.ts"
      ],
      "@ascii-chat/shared/wasm": [
        "../packages/shared/src/wasm/index.ts"
      ],
      "@ascii-chat/shared/utils": ["../packages/shared/src/utils/index.ts"],
      "@ascii-chat/shared/styles/*": ["../packages/shared/src/styles/*"]
    },
    "skipLibCheck": true,
    "moduleResolution": "bundler"
  },
  "include": ["src"]
}
