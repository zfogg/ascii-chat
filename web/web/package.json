{
  "name": "web",
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "bash scripts/build.sh",
    "preview": "vp preview",
    "start:caddy": "caddy run --config /etc/caddy/Caddyfile",
    "vite:build": "vp build",
    "type-check": "pnpm exec tsc --noEmit",
    "format": "vp fmt .",
    "format:check": "vp fmt --check .",
    "lint": "vp lint . --max-warnings 0",
    "test": "vp test",
    "test:unit": "vp test run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "wasm:build": "cd ../.. && cmake --build build --target mirror-web client-web",
    "wasm:build:mirror": "cd ../.. && cmake --build build --target mirror-web",
    "wasm:build:client": "cd ../.. && cmake --build build --target client-web",
    "wasm:watch": "nodemon --watch ../../../lib --watch ../../../src/web -e c,h --exec 'pnpm run wasm:build'",
    "wasm:clean": "rm -rf src/wasm/dist",
    "prebuild": "cd ../.. && ls build 2>/dev/null 1>&2 || cmake --preset default -B build || true"
  },
  "dependencies": {
    "@ascii-chat/shared": "workspace:*",
    "@headlessui/react": "^2.2.9",
    "hls.js": "^1.6.15",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.24",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "terser": "^5.46.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vite": "catalog:",
    "vite-plugin-sitemap": "^0.8.2",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "ws": "^8.19.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-arm64-gnu": "^4.59.0"
  }
}
