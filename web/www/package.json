{
  "name": "www",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"ls api.js | entr -rdc vite --port 5173 | tee vite.log\" \"node api.js | tee api.log\" \"scripts/manpage-watch.sh\"",
    "api": "node api.js",
    "start": "concurrently \"vite --port 5173\" \"node api.js\"",
    "start:caddy": "concurrently \"node api.js\" \"caddy run --config /etc/caddy/Caddyfile\"",
    "format": "vp fmt .",
    "format:check": "vp fmt --check .",
    "build": "bash scripts/build.sh",
    "lint": "vp lint . --max-warnings 0",
    "type-check": "pnpm exec tsc --noEmit",
    "preview": "vp preview",
    "vite:build": "vp build"
  },
  "dependencies": {
    "@ascii-chat/shared": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-react": "^5.1.3",
    "autoprefixer": "^10.4.24",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "globals": "^17.3.0",
    "morgan": "^1.10.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vite": "catalog:",
    "vite-plugin-sitemap": "^0.8.2",
    "winston": "^3.11.0",
    "vite-plus": "catalog:"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-arm64-gnu": "^4.59.0"
  }
}
