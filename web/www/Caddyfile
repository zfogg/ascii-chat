:80 {
  # API requests go to Express backend on port 3001
  handle /api/* {
    reverse_proxy * localhost:3001
  }

  # Static files from dist/
  root * /app/www/dist
  file_server

  # SPA routing: fall back to index.html for client-side routing
  try_files {path} /index.html
}

:3001 {
  reverse_proxy * localhost:3001
}
