# Caddy reverse proxy gateway for ascii-chat web services
# Routes requests to backend services based on domain names
# TLS/certificates handled by Traefik (Coolify reverse proxy)

# Default (uncomment and update for production domains)
# ascii-chat.com, www.ascii-chat.com {
#   reverse_proxy www:5173
# }

# Discovery service
# discovery.ascii-chat.com {
#   reverse_proxy discovery:3000
# }

# Web client
# web.ascii-chat.com {
#   reverse_proxy web:3000
# }

# HTTP-only routing (Traefik terminates HTTPS)
# Traefik handles TLS/certificates and forwards HTTP to Caddy
http://*.ascii-chat.com, http://ascii-chat.com {
  # Route based on subdomain
  @www host ascii-chat.com www.ascii-chat.com
  @discovery host discovery.ascii-chat.com
  @web host web.ascii-chat.com

  handle @www {
    reverse_proxy www:5173
  }

  handle @discovery {
    reverse_proxy discovery:5174
  }

  handle @web {
    reverse_proxy web:3000
  }

  # Health check endpoint
  handle /health {
    respond "OK" 200
  }

  # Catch-all for unmatched domains (fallback to www service)
  handle {
    reverse_proxy www:5173
  }
}
