{
  "type": "module",
  "name": "ascii-chat-web",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*",
    "www",
    "discovery",
    "web"
  ],
  "scripts": {
    "dev": "bun run --filter './www' --filter './discovery' --filter './web' dev",
    "build": "bun run --filter '*' build",
    "build:shared": "bun run --filter '@ascii-chat/shared' build",
    "build:websites": "bun run --filter './www' --filter './discovery' --filter './web' build",
    "type-check": "bun run --filter './www' --filter './discovery' --filter './web' type-check",
    "lint": "bun run --filter './www' --filter './discovery' --filter './web' lint",
    "format": "bun run --filter './www' --filter './discovery' --filter './web' format",
    "format:check": "bun run --filter './www' --filter './discovery' --filter './web' format:check",
    "build:sites": "bun run build:shared && bun run --filter './www' --filter './discovery' --filter './web' build"
  }
}
