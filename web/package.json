{
  "type": "module",
  "name": "ascii-chat-web",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*",
    "www",
    "discovery",
    "web"
  ],
  "scripts": {
    "dev": "bun run --filter './www' --filter './discovery' --filter './web' dev",
    "build": "bun run --filter '*' build",
    "build:shared": "bun run --filter '@ascii-chat/shared' build",
    "build:websites": "bun run --filter './www' --filter './discovery' --filter './web' build",
    "type-check": "bun run --filter './www' --filter './discovery' --filter './web' type-check",
    "lint": "bun run --filter './www' --filter './discovery' --filter './web' lint",
    "format": "bun run --filter './www' --filter './discovery' --filter './web' format",
    "format:check": "bun run --filter './www' --filter './discovery' --filter './web' format:check",
    "build:sites": "bun run build:shared && bun run --filter './www' --filter './discovery' --filter './web' build"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@headlessui/react": "^2.2.9",
    "@pablo-lion/xterm-react": "^1.1.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vercel/analytics": "^1.6.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "eslint": "^9.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.55.0",
    "xterm": "^5.3.0"
  },
  "dependencies": {
    "morgan": "^1.10.1",
    "react-helmet-async": "^2.0.5",
    "winston": "^3.19.0"
  }
}
