# Unified Caddyfile for all web applications (www, discovery, web)
# Caddy serves all three apps by subdomain

# Development/local: localhost subdomains without HTTPS
http://localhost http://www.localhost http://discovery.localhost http://web.localhost {
  # www.localhost and localhost -> www app
  @wwwlocal {
    host localhost www.localhost
  }
  handle @wwwlocal {
    root * /app/web/www/dist
    file_server
    try_files {path} /index.html
  }

  # discovery.localhost -> discovery app
  @discoverylocal {
    host discovery.localhost
  }
  handle @discoverylocal {
    root * /app/web/discovery/dist
    file_server
    try_files {path} /index.html
  }

  # web.localhost -> web app
  @weblocal {
    host web.localhost
  }
  handle @weblocal {
    root * /app/web/web/dist
    file_server
    try_files {path} /index.html
  }

  # Default to www
  root * /app/web/www/dist
  file_server
  try_files {path} /index.html
}

# Production: ascii-chat.com subdomains with HTTPS
ascii-chat.com www.ascii-chat.com {
  root * /app/web/www/dist
  file_server
  try_files {path} /index.html
}

discovery.ascii-chat.com {
  root * /app/web/discovery/dist
  file_server
  try_files {path} /index.html
}

web.ascii-chat.com {
  root * /app/web/web/dist
  file_server
  try_files {path} /index.html
}
