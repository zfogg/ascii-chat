# Unified Caddyfile for all web applications (www, discovery, web)
# Caddy serves all three apps by subdomain

# Development/local: localhost subdomains without HTTPS
http://localhost http://www.localhost http://discovery.localhost http://web.localhost http://100.104.17.128 http://127.0.1.1 http://manjaro-twopal http://workbook-pro {
  # www.localhost and localhost -> www app
  @wwwlocal {
    host localhost www.localhost 127.0.1.1 manjaro-twopal workbook-pro
  }
  handle @wwwlocal {
    root * /app/web/www/dist

    # COEP/COOP headers for SharedArrayBuffer support (required for WASM)
    header Cross-Origin-Embedder-Policy "require-corp"
    header Cross-Origin-Opener-Policy "same-origin"

    # Accept-Ranges header for video streaming on iOS
    header Accept-Ranges "bytes"

    # Cache static assets with content hashes for 1 year (immutable)
    handle /assets/* {
      header Cache-Control "public, max-age=31536000, immutable"
      header Cross-Origin-Resource-Policy "cross-origin"
      header Accept-Ranges "bytes"
      file_server
    }

    # SPA routing with 1 hour cache
    @sparoutes {
      not path /assets/*
    }
    handle @sparoutes {
      header Cache-Control "public, max-age=3600"
      try_files {path} /index.html
      file_server
    }
  }

  # discovery.localhost -> discovery app
  @discoverylocal {
    host discovery.localhost
  }
  handle @discoverylocal {
    root * /app/web/discovery/dist

    # Cache static assets with content hashes for 1 year (immutable)
    handle /assets/* {
      header Cache-Control "public, max-age=31536000, immutable"
      file_server
    }

    # SPA routing with 1 hour cache
    @sparoutesdiscovery {
      not path /assets/*
    }
    handle @sparoutesdiscovery {
      header Cache-Control "public, max-age=3600"
      try_files {path} /index.html
      file_server
    }
  }

  # web.localhost -> web app
  @weblocal {
    host web.localhost
  }
  handle @weblocal {
    root * /app/web/web/dist

    # COEP/COOP headers for SharedArrayBuffer support (required for WASM threads)
    header Cross-Origin-Embedder-Policy "require-corp"
    header Cross-Origin-Opener-Policy "same-origin"

    # CORS for .wasm files (allows ascii-chat.com to fetch mirror.wasm cross-origin)
    handle /wasm/* {
      header Access-Control-Allow-Origin "*"
      header Cross-Origin-Resource-Policy "cross-origin"
      file_server
    }

    # Cache static assets with content hashes for 1 year (immutable)
    handle /assets/* {
      header Cache-Control "public, max-age=31536000, immutable"
      file_server
    }

    # SPA routing with 1 hour cache
    @sparoutesweb {
      not path /assets/* /wasm/*
    }
    handle @sparoutesweb {
      header Cache-Control "public, max-age=3600"
      try_files {path} /index.html
      file_server
    }
  }
}

# Production: ascii-chat.com subdomains (Cloudflare terminates TLS, Caddy serves HTTP)
http://ascii-chat.com http://www.ascii-chat.com {
  root * /app/web/www/dist

  # COEP/COOP headers for SharedArrayBuffer support (required for WASM)
  header Cross-Origin-Embedder-Policy "require-corp"
  header Cross-Origin-Opener-Policy "same-origin"

  # Accept-Ranges header for all responses (needed for video streaming on iOS)
  header Accept-Ranges "bytes"

  # Proxy API requests to Node.js backend
  handle /api/* {
    reverse_proxy localhost:3001
  }

  # Cache static assets with content hashes for 1 year (immutable)
  handle /assets/* {
    header Cache-Control "public, max-age=31536000, immutable"
    header Cross-Origin-Resource-Policy "cross-origin"
    header Accept-Ranges "bytes"
    file_server
  }

  # SPA routing with 1 hour cache
  @sparouteswww {
    not path /assets/* /api/*
  }
  handle @sparouteswww {
    header Cache-Control "public, max-age=3600"
    try_files {path} /index.html
    file_server
  }
}

http://discovery.ascii-chat.com {
  root * /app/web/discovery/dist

  # Cache static assets with content hashes for 1 year (immutable)
  handle /assets/* {
    header Cache-Control "public, max-age=31536000, immutable"
    header Accept-Ranges "bytes"
    file_server
  }

  # SPA routing with 1 hour cache
  @sparoutesdiscoveryprod {
    not path /assets/*
  }
  handle @sparoutesdiscoveryprod {
    header Cache-Control "public, max-age=3600"
    try_files {path} /index.html
    file_server
  }
}

http://web.ascii-chat.com {
  root * /app/web/web/dist

  # COEP/COOP headers for SharedArrayBuffer support (required for WASM threads)
  header Cross-Origin-Embedder-Policy "require-corp"
  header Cross-Origin-Opener-Policy "same-origin"

  # CORS for .wasm files (allows ascii-chat.com and www.ascii-chat.com to fetch mirror.wasm cross-origin)
  handle /wasm/* {
    header Access-Control-Allow-Origin "*"
    header Cross-Origin-Resource-Policy "cross-origin"
    file_server
  }

  # Cache static assets with content hashes for 1 year (immutable)
  handle /assets/* {
    header Cache-Control "public, max-age=31536000, immutable"
    header Accept-Ranges "bytes"
    file_server
  }

  # SPA routing with 1 hour cache
  @sparouteswebprod {
    not path /assets/* /wasm/*
  }
  handle @sparouteswebprod {
    header Cache-Control "public, max-age=3600"
    try_files {path} /index.html
    file_server
  }
}
