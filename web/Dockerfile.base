# Base Dockerfile for all web projects
# Provides Node.js, bun, and monorepo dependencies
ARG SOURCE_COMMIT
FROM node:22-alpine

# Install bash, git, and bun
RUN apk add --no-cache bash git && npm install -g bun

WORKDIR /app

# Copy .git directory explicitly (needed for getCommitSha.ts to use git rev-parse)
COPY .git .git

# Copy entire monorepo (preserves workspace structure)
COPY . .

# Pass SOURCE_COMMIT from Coolify as environment variable for build-time use
ENV SOURCE_COMMIT=${SOURCE_COMMIT}

# Install dependencies for entire monorepo workspace
RUN bun install
