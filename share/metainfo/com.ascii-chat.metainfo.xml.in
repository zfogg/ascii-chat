<?xml version="1.0" encoding="UTF-8"?>
<component type="console-application">
  <id>com.ascii-chat</id>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <name>ascii chat</name>
  <summary>Video chat in your terminal</summary>

  <description>
    <p>
      ascii-chat is a terminal-based video chat application that converts webcam video
      to ASCII art in real-time. It supports multiple clients connecting to a single
      server, with video mixing and audio streaming capabilities.
    </p>
    <p>Key features:</p>
    <ul>
      <li>Real-time webcam to ASCII conversion</li>
      <li>Multi-client video grid layout (2x2, 3x3, etc.)</li>
      <li>Audio streaming with mixing</li>
      <li>End-to-end encryption</li>
      <li>SSH and GPG authentication with agent support</li>
      <li>Cross-platform support (Linux, macOS, Windows)</li>
    </ul>
  </description>

  <launchable type="desktop-id">ascii-chat.desktop</launchable>

  <url type="homepage">https://github.com/zfogg/ascii-chat</url>
  <url type="bugtracker">https://github.com/zfogg/ascii-chat/issues</url>
  <url type="help">https://zfogg.github.io/ascii-chat/</url>
  <url type="vcs-browser">https://github.com/zfogg/ascii-chat</url>

  <developer id="gg.zfo">
    <name>Zachary Fogg</name>
  </developer>

  <provides>
    <binary>ascii-chat</binary>
  </provides>

  <categories>
    <category>Network</category>
    <category>Chat</category>
    <category>AudioVideo</category>
    <category>Video</category>
  </categories>

  <keywords>
    <keyword>video</keyword>
    <keyword>chat</keyword>
    <keyword>ascii</keyword>
    <keyword>terminal</keyword>
    <keyword>webcam</keyword>
    <keyword>streaming</keyword>
    <keyword>encryption</keyword>
    <keyword>cli</keyword>
  </keywords>

  <screenshots>
    <screenshot type="default">
      <caption>ascii-chat client showing video converted to ASCII art</caption>
      <image type="source">https://raw.githubusercontent.com/zfogg/ascii-chat/master/images/screenshot.png</image>
    </screenshot>
  </screenshots>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="@PROJECT_VERSION@" date="@PROJECT_VERSION_DATE@">
      <description>
        <p>Latest release with enhanced platform support and bug fixes.</p>
      </description>
      <url type="details">@PROJECT_REPOSITORY_URL@/releases/tag/v@PROJECT_VERSION@</url>
    </release>
  </releases>

  <supports>
    <control>keyboard</control>
    <control>console</control>
  </supports>

  <requires>
    <display_length compare="ge">80</display_length>
  </requires>
</component>
