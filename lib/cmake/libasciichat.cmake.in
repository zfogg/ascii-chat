# ascii-chat CMake Package Config
#
# Usage:
#   find_package(ascii-chat REQUIRED)
#   target_link_libraries(your-target PRIVATE ascii-chat::shared)  # dynamic
#   target_link_libraries(your-target PRIVATE ascii-chat::static)  # static
#
# Targets:
#   ascii-chat::shared - Shared library
#   ascii-chat::static - Static library
#
# Required dependencies (install via package manager):
#   libsodium, zstd, portaudio, opus, pcre2, sqlite3, openssl,
#   freetype, fontconfig, ffmpeg, libwebsockets, miniupnpc
#
# Optional dependencies:
#   mimalloc (used if built with USE_MIMALLOC=@USE_MIMALLOC@)
#
# Bundled in libasciichat.a (not required to install):
#   BearSSL, yyjson, WebRTC AEC3, libdatachannel

cmake_minimum_required(VERSION 3.16)

# Compute install prefix from this file's location
# Config is installed to lib/cmake/ascii-chat/ascii-chat-config.cmake
get_filename_component(_IMPORT_PREFIX "${CMAKE_CURRENT_LIST_DIR}/../../" ABSOLUTE)

set(_INCLUDE_DIRS "${_IMPORT_PREFIX}/include/ascii-chat")

# =============================================================================
# ascii-chat::shared - Dynamic library
# =============================================================================
# Shared library consumers don't need transitive dependencies
# (they are embedded in the dylib)
if(NOT TARGET ascii-chat::shared)
    add_library(ascii-chat::shared SHARED IMPORTED)
    set_target_properties(ascii-chat::shared PROPERTIES
        IMPORTED_LOCATION "${_IMPORT_PREFIX}/lib/libasciichat@CMAKE_SHARED_LIBRARY_SUFFIX@"
        IMPORTED_SONAME "libasciichat@CMAKE_SHARED_LIBRARY_SUFFIX@"
        VERSION "@ASCIICHAT_LIB_VERSION@"
        SOVERSION "@ASCIICHAT_LIB_VERSION_MAJOR@"
        INTERFACE_INCLUDE_DIRECTORIES "${_INCLUDE_DIRS}"
    )
    # No INTERFACE_LINK_LIBRARIES — all deps are embedded in the dylib
endif()

# =============================================================================
# ascii-chat::static - Static library
# =============================================================================
# Bundled: BearSSL, yyjson, WebRTC AEC3, libdatachannel (baked into the archive)
# Required: libsodium, zstd, portaudio, opus, pcre2, sqlite3, libwebsockets,
#           openssl, freetype, fontconfig, ffmpeg, miniupnpc
# Optional: mimalloc (if built with USE_MIMALLOC)
if(NOT TARGET ascii-chat::static)
    add_library(ascii-chat::static STATIC IMPORTED)
    set_target_properties(ascii-chat::static PROPERTIES
        IMPORTED_LOCATION "${_IMPORT_PREFIX}/lib/libasciichat.a"
        VERSION "@ASCIICHAT_LIB_VERSION@"
        INTERFACE_INCLUDE_DIRECTORIES "${_INCLUDE_DIRS}"
        INTERFACE_COMPILE_OPTIONS "-fPIC"
    )

    # Core required dependencies (all platforms)
    find_package(PkgConfig QUIET)
    if(PkgConfig_FOUND)
        # Core crypto, compression, and I/O
        pkg_check_modules(_LIBSODIUM QUIET IMPORTED_TARGET libsodium)
        pkg_check_modules(_ZSTD QUIET IMPORTED_TARGET libzstd)
        pkg_check_modules(_PORTAUDIO QUIET IMPORTED_TARGET portaudio-2.0)
        pkg_check_modules(_OPUS QUIET IMPORTED_TARGET opus)
        pkg_check_modules(_PCRE2 QUIET IMPORTED_TARGET libpcre2-8)
        pkg_check_modules(_SQLITE3 QUIET IMPORTED_TARGET sqlite3)
        pkg_check_modules(_LWS QUIET IMPORTED_TARGET libwebsockets)

        # Optional: mimalloc (only if ascii-chat was built with it)
        set(_ASCIICHAT_BUILT_WITH_MIMALLOC @USE_MIMALLOC@)
        if(_ASCIICHAT_BUILT_WITH_MIMALLOC)
            pkg_check_modules(_MIMALLOC QUIET IMPORTED_TARGET mimalloc)
        endif()

        # Media: FFmpeg components
        pkg_check_modules(_FFMPEG_FORMAT QUIET IMPORTED_TARGET libavformat)
        pkg_check_modules(_FFMPEG_CODEC QUIET IMPORTED_TARGET libavcodec)
        pkg_check_modules(_FFMPEG_UTIL QUIET IMPORTED_TARGET libavutil)
        pkg_check_modules(_FFMPEG_SWSCALE QUIET IMPORTED_TARGET libswscale)
        pkg_check_modules(_FFMPEG_SWRESAMPLE QUIET IMPORTED_TARGET libswresample)

        # Security and rendering
        pkg_check_modules(_OPENSSL QUIET IMPORTED_TARGET openssl)
        pkg_check_modules(_FREETYPE QUIET IMPORTED_TARGET freetype2)
        pkg_check_modules(_MINIUPNPC QUIET IMPORTED_TARGET miniupnpc)
        pkg_check_modules(_FONTCONFIG QUIET IMPORTED_TARGET fontconfig)

        # Add all found libraries to INTERFACE_LINK_LIBRARIES
        foreach(_dep
            _LIBSODIUM _ZSTD _PORTAUDIO _OPUS _PCRE2 _SQLITE3 _LWS
            _MIMALLOC
            _FFMPEG_FORMAT _FFMPEG_CODEC _FFMPEG_UTIL _FFMPEG_SWSCALE _FFMPEG_SWRESAMPLE
            _OPENSSL _FREETYPE _MINIUPNPC _FONTCONFIG
        )
            if(${_dep}_FOUND)
                set_property(TARGET ascii-chat::static APPEND PROPERTY
                    INTERFACE_LINK_LIBRARIES PkgConfig::${_dep})
            endif()
        endforeach()
    else()
        # Fallback: try to find libraries without pkg-config
        find_library(_LIBSODIUM_LIB sodium REQUIRED)
        find_library(_ZSTD_LIB zstd REQUIRED)
        find_library(_PORTAUDIO_LIB portaudio REQUIRED)
        find_library(_OPUS_LIB opus REQUIRED)
        find_library(_PCRE2_LIB pcre2-8 REQUIRED)
        find_library(_SQLITE3_LIB sqlite3 REQUIRED)
        find_library(_LWS_LIB websockets REQUIRED)

        set_property(TARGET ascii-chat::static APPEND PROPERTY
            INTERFACE_LINK_LIBRARIES ${_LIBSODIUM_LIB} ${_ZSTD_LIB} ${_PORTAUDIO_LIB}
                ${_OPUS_LIB} ${_PCRE2_LIB} ${_SQLITE3_LIB} ${_LWS_LIB}
        )

        # Optional: mimalloc (only if ascii-chat was built with it)
        set(_ASCIICHAT_BUILT_WITH_MIMALLOC @USE_MIMALLOC@)
        if(_ASCIICHAT_BUILT_WITH_MIMALLOC)
            find_library(_MIMALLOC_LIB mimalloc)
            if(_MIMALLOC_LIB)
                set_property(TARGET ascii-chat::static APPEND PROPERTY
                    INTERFACE_LINK_LIBRARIES ${_MIMALLOC_LIB})
            endif()
        endif()

        # FFmpeg
        find_library(_AVFORMAT_LIB avformat)
        find_library(_AVCODEC_LIB avcodec)
        find_library(_AVUTIL_LIB avutil)
        find_library(_SWSCALE_LIB swscale)
        find_library(_SWRESAMPLE_LIB swresample)
        if(_AVFORMAT_LIB AND _AVCODEC_LIB AND _AVUTIL_LIB AND _SWSCALE_LIB AND _SWRESAMPLE_LIB)
            set_property(TARGET ascii-chat::static APPEND PROPERTY
                INTERFACE_LINK_LIBRARIES ${_AVFORMAT_LIB} ${_AVCODEC_LIB} ${_AVUTIL_LIB}
                    ${_SWSCALE_LIB} ${_SWRESAMPLE_LIB})
        endif()

        # OpenSSL
        find_package(OpenSSL QUIET)
        if(OPENSSL_FOUND)
            set_property(TARGET ascii-chat::static APPEND PROPERTY
                INTERFACE_LINK_LIBRARIES OpenSSL::SSL OpenSSL::Crypto)
        endif()

        # FreeType
        find_library(_FREETYPE_LIB freetype)
        if(_FREETYPE_LIB)
            set_property(TARGET ascii-chat::static APPEND PROPERTY
                INTERFACE_LINK_LIBRARIES ${_FREETYPE_LIB})
        endif()

        # miniupnpc
        find_library(_MINIUPNPC_LIB miniupnpc)
        if(_MINIUPNPC_LIB)
            set_property(TARGET ascii-chat::static APPEND PROPERTY
                INTERFACE_LINK_LIBRARIES ${_MINIUPNPC_LIB})
        endif()

        # fontconfig
        find_library(_FONTCONFIG_LIB fontconfig)
        if(_FONTCONFIG_LIB)
            set_property(TARGET ascii-chat::static APPEND PROPERTY
                INTERFACE_LINK_LIBRARIES ${_FONTCONFIG_LIB})
        endif()
    endif()

    # System libraries and threading
    find_package(Threads QUIET)
    if(Threads_FOUND)
        set_property(TARGET ascii-chat::static APPEND PROPERTY
            INTERFACE_LINK_LIBRARIES Threads::Threads)
    endif()

    # Platform-specific system libraries
    if(APPLE)
        set_property(TARGET ascii-chat::static APPEND PROPERTY
            INTERFACE_LINK_LIBRARIES
                "-framework Foundation"
                "-framework AVFoundation"
                "-framework CoreMedia"
                "-framework CoreVideo"
                "-framework CoreAudio"
                "-framework AudioUnit"
                "-framework AudioToolbox"
                "-framework CoreServices"
                "-framework IOKit"
                m
                c++
        )
    elseif(UNIX AND NOT APPLE)
        set_property(TARGET ascii-chat::static APPEND PROPERTY
            INTERFACE_LINK_LIBRARIES m dl rt stdc++)
    elseif(WIN32)
        set_property(TARGET ascii-chat::static APPEND PROPERTY
            INTERFACE_LINK_LIBRARIES ws2_32 user32 advapi32 dbghelp mf mfplat
                mfreadwrite mfuuid ole32 crypt32 winmm iphlpapi)
    endif()
endif()

# Package info
set(ascii-chat_FOUND TRUE)
set(ascii-chat_VERSION "@PROJECT_VERSION@")
set(ascii-chat_INCLUDE_DIRS ${_INCLUDE_DIRS})

# Version compatibility checking
if(DEFINED ascii-chat_FIND_VERSION)
    if(ascii-chat_VERSION VERSION_LESS ascii-chat_FIND_VERSION)
        set(ascii-chat_FOUND FALSE)
        if(ascii-chat_FIND_REQUIRED)
            message(FATAL_ERROR "ascii-chat version ${ascii-chat_VERSION} is less than required version ${ascii-chat_FIND_VERSION}")
        endif()
    endif()
endif()

unset(_IMPORT_PREFIX)
unset(_INCLUDE_DIRS)

if(NOT ascii-chat_FIND_QUIETLY)
    message(STATUS "Found ascii-chat: ${ascii-chat_VERSION}")
endif()
