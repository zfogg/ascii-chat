# ascii-chat pkg-config file (shared library)
#
# This file is for shared library consumers only.
# Shared library consumers do NOT need transitive dependencies
# (they are embedded in the dylib).
#
# Usage:
#   pkg-config --cflags --libs ascii-chat

prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: ascii-chat
Description: Video chat in your terminal
Version: @PROJECT_VERSION@
URL: @PROJECT_HOMEPAGE_URL@

# Shared library consumers need only headers and the library itself
# All dependencies are embedded in the dylib
Libs: -L${libdir} -lasciichat

# Include directories
Cflags: -I${includedir} -I${includedir}/ascii-chat
